# # Dependencies
# node_modules/
# npm-debug.log*
# yarn-debug.log*
# yarn-error.log*

# # Environment variables
# .env
# .env.local
# .env.development.local
# .env.test.local
# .env.production.local

# # Build outputs
# dist/
# build/
# .DS_Store

# # IDE
# .vscode/
# .idea/
# *.swp
# *.swo

# # OS
# Thumbs.db
# .DS_Store

cat > .gitignore << 'EOF'
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.production

# Build outputs
dist/
build/
.DS_Store

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
.DS_Store

# Logs
*.log

# MongoDB data
data/
mongodb-data/